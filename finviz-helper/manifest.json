{
  "manifest_version": 3,
  "name": "JerryTrade Site Helper",
  "version": "2.3",
  "description": "Lets dashboard.jerrytrade.com embed finviz.com, tradingview.com and unusualwhales.com, and keeps your logins working inside the embedded views. No data access, no browsing history, no other sites.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "cookies",
    "contentSettings",
    "storage"
  ],
  "host_permissions": [
    "https://finviz.com/*",
    "https://elite.finviz.com/*",
    "https://dashboard.jerrytrade.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://www.tradingview.com/*",
    "https://tradingview.com/*",
    "https://*.tradingview.com/*",
    "https://unusualwhales.com/*",
    "https://*.unusualwhales.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "allow_jerry_frame",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://dashboard.jerrytrade.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "announce.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://finviz.com/*",
        "https://elite.finviz.com/*"
      ],
      "js": [
        "ticker-sync.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://*.tradingview.com/*"
      ],
      "js": [
        "tv-sync.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://unusualwhales.com/*",
        "https://*.unusualwhales.com/*"
      ],
      "js": [
        "uw-sync.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}