{
  "manifest_version": 3,
  "name": "JerryTrade Finviz Helper",
  "version": "1.4",
  "description": "Lets dashboard.jerrytrade.com embed finviz.com and keeps your Finviz login working inside the embedded view. No data access, no browsing history, no other sites.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "cookies",
    "contentSettings"
  ],
  "host_permissions": [
    "https://finviz.com/*",
    "https://elite.finviz.com/*",
    "https://dashboard.jerrytrade.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "allow_jerry_frame",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://dashboard.jerrytrade.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": [
        "announce.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://finviz.com/*",
        "https://elite.finviz.com/*"
      ],
      "js": [
        "ticker-sync.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}